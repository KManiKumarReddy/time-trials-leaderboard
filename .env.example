# Copy this file to .env.local and fill in your values
# .env.local is gitignored and will NOT be committed

# Your GitHub Personal Access Token (classic, with 'gist' scope)
GH_PAT=ghp_xxxxxxxxxxxxxxxxxxxx

# Admin password (used to encrypt/decrypt the PAT, same one you type in the browser)
ADMIN_PASSWORD=runners1234

# Your GitHub repository (format: owner/repo)
GITHUB_REPOSITORY=KManiKumarReddy/time-trials-leaderboard

# Your public Gist ID (the long hash from the gist URL)
GIST_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
